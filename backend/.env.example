# ============================================================
#  BACKEND .env — Society Management App
# ============================================================

# ----- Core Server -----
PORT=5000
NODE_ENV=development

# ----- MongoDB -----
# Local:  mongodb://localhost:27017/society_management
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/society_management
MONGO_URI=mongodb://localhost:27017/society_management

# ----- JWT -----
# Generate a strong random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=society_management_dev_secret_change_in_production

# ----- CORS -----
# URL where your React app is running
FRONTEND_URL=http://localhost:5173

# ============================================================
#  RAZORPAY  (Payments)
# ============================================================
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Leave as-is (rzp_test_xxxxxxxxxxxx) to use MOCK payment mode (no real charges)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================================
#  GMAIL  (Visitor QR Pass Emails)
# ============================================================
# Use a Gmail App Password — NOT your regular Gmail password
# Enable at: https://myaccount.google.com/apppasswords
# Leave blank to disable email sending (app still works without it)
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# ============================================================
#  OPENAI  (AI Chatbot)
# ============================================================
# Get from: https://platform.openai.com/api-keys
# Leave as sk-xxxx to use the LOCAL keyword parser fallback (no API calls)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ============================================================
#  CLOUDINARY  (Document Vault File Uploads)
# ============================================================
# Get from: https://console.cloudinary.com → Dashboard
# Leave blank to store files locally in /backend/public/uploads/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
