# ============================================================
#  FRONTEND .env — Society Management App  (Vite)
# ============================================================
# NOTE: All variables MUST start with VITE_ to be accessible
#       in the React app via import.meta.env.VITE_*

# ----- Backend API Base URL -----
# Point this to wherever your backend server is running
# Local dev:    http://localhost:5000/api
# Production:   https://yourdomain.com/api
VITE_API_URL=http://localhost:5000/api

# ----- Socket.io Server URL -----
# Must match the backend host WITHOUT the /api suffix
# Local dev:    http://localhost:5000
# Production:   https://yourdomain.com
VITE_SOCKET_URL=http://localhost:5000
